# Cognia — Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# .env NUNCA debe subirse al repositorio (ya está en .gitignore).

# ── Ollama (LLM local) ─────────────────────────────────────────────────
# URL del servidor Ollama. Por defecto apunta a localhost.
OLLAMA_URL=http://localhost:11434

# ── HuggingFace ────────────────────────────────────────────────────────
# Token para descargar modelos privados o con acceso restringido.
# Conseguilo en: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Coordinator ────────────────────────────────────────────────────────
# URL del coordinador del swarm. Dejar vacío para modo local (sin swarm).
COGNIA_COORDINATOR_URL=

# Token HMAC de contribuidor, emitido por el coordinador al registrar un nodo.
# Se obtiene del campo "contributor_token" en la respuesta de POST /api/node/register.
# Requerido junto con COGNIA_COORDINATOR_URL para activar el aprendizaje federado.
COGNIA_CONTRIBUTOR_TOKEN=

# Clave de autenticación para endpoints de admin del coordinador.
# Dejar vacío en desarrollo (abre todos los endpoints sin auth).
# En producción: usar un string largo y aleatorio.
COORDINATOR_KEY=

# Orígenes CORS permitidos en el coordinador (JSON array).
# Por defecto: localhost:3000, localhost:8001, localhost:8765
COORDINATOR_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8001","http://localhost:8765"]

# ── Desktop API ────────────────────────────────────────────────────────
# Puerto donde corre cognia_desktop_api.py (bridge para Electron).
COGNIA_DESKTOP_PORT=8765

# ── Swarm / Inferencia distribuida ────────────────────────────────────
# Nombre del modelo base del swarm.
COGNIA_SWARM_MODEL=llama-3.2-3b-q4

# Timeout en segundos para esperar respuesta de un shard.
SWARM_TIMEOUT_S=30

# ── Web / Railway ──────────────────────────────────────────────────────
# Puerto del servidor FastAPI principal. Railway lo inyecta automáticamente.
PORT=8000

# ── Seguridad / Privacidad ───────────────────────────────────────────────
# Clave para los endpoints de datos de usuario (/api/user/data/export, DELETE).
# Requerida para que esos endpoints funcionen. String largo y aleatorio.
COGNIA_ADMIN_KEY=

# Passphrase para cifrar columnas sensibles en cognia_memory.db.
# Solo se usa al correr scripts/migrate_db_encrypt.py.
COGNIA_ENCRYPT_PASSPHRASE=

# ── Logging ────────────────────────────────────────────────────────────
# Ruta del archivo de log. Dejar vacío para loguear solo a stdout.
COGNIA_LOG_FILE=
